@page
@using KaraokePlatform.Data.Entities
@model KaraokePlatform.Pages.Admin.ManageUsersModel
@{
    ViewData["Title"] = "Управление пользователями";
}

<div class="container py-4">
    <div class="row mb-4 align-items-center">
        <div class="col">
            <h1 class="h3 fw-bold" style="color: var(--accent-color);">
                <i class="bi bi-shield-lock me-2"></i>Панель администратора
            </h1>
            <p class="small mb-0" style="color: var(--text-secondary);">Создание учетных записей и аудит активности пользователей</p>
        </div>
        <div class="col-auto">
            <a class="btn btn-gallery-adaptive btn-sm" asp-page="/Dashboard">
                <i class="bi bi-arrow-left me-1"></i>Вернуться в Dashboard
            </a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert border-0 rounded-4 mb-4 bg-danger bg-opacity-15" role="alert" style="color: #ef4444; border: 1px solid rgba(239,68,68,0.3) !important;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@Model.ErrorMessage
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert border-0 rounded-4 mb-4 bg-success bg-opacity-15" role="alert" style="color: #22c55e; border: 1px solid rgba(34,197,94,0.3) !important;">
            <i class="bi bi-check-circle-fill me-2"></i>@Model.SuccessMessage
        </div>
    }

    <div class="row g-4">
        <!-- Create User Card -->
        <div class="col-lg-4">
            <div class="card manage-users-card p-4 h-100">
                <h5 class="fw-bold mb-4">
                    <i class="bi bi-person-plus-fill me-2" style="color: var(--accent-color);"></i>Новый аккаунт
                </h5>

                <form method="post" asp-page-handler="Create">
                    <div class="mb-3">
                        <label asp-for="NewUsername" class="form-label small fw-semibold" style="color: var(--text-secondary);">Имя пользователя</label>
                        <input asp-for="NewUsername" class="form-control" required autocomplete="off" placeholder="username" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label small fw-semibold" style="color: var(--text-secondary);">Пароль</label>
                        <input asp-for="NewPassword" type="text" class="form-control" required autocomplete="off"
                               placeholder="Надёжный пароль" />
                    </div>

                    <div class="mb-4">
                        <label asp-for="NewRole" class="form-label small fw-semibold" style="color: var(--text-secondary);">Роль в системе</label>
                        <select asp-for="NewRole" class="form-select"
                                asp-items="Html.GetEnumSelectList<Role>()"></select>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 fw-bold py-2 rounded-pill">
                        <i class="bi bi-person-plus me-2"></i>Создать пользователя
                    </button>
                </form>
            </div>
        </div>

        <!-- Users Table Card -->
        <div class="col-lg-8">
            <div class="card manage-users-card p-4">
                <h5 class="fw-bold mb-4">
                    <i class="bi bi-people-fill me-2" style="color: var(--accent-color);"></i>Список пользователей
                </h5>

                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th class="small" style="color: var(--text-secondary); font-weight: 600;">Логин</th>
                                <th class="small" style="color: var(--text-secondary); font-weight: 600;">Роль</th>
                                <th class="small" style="color: var(--text-secondary); font-weight: 600;">Регистрация</th>
                                <th class="small text-center" style="color: var(--text-secondary); font-weight: 600;">Видео</th>
                                <th class="small text-end" style="color: var(--text-secondary); font-weight: 600;">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model.ExistingUsers)
                            {
                                <tr>
                                    <td class="fw-bold">@user.Username</td>
                                    <td>
                                        @if (user.Role == Role.Admin)
                                        {
                                            <span class="badge badge-admin-glass rounded-pill px-2 py-1">Admin</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-user-glass rounded-pill px-2 py-1">User</span>
                                        }
                                    </td>
                                    <td class="small" style="color: var(--text-secondary);">@user.CreatedAt.ToLocalTime().ToString("d")</td>
                                    <td class="text-center fw-bold" style="color: var(--text-secondary);">@user.Tasks.Count</td>
                                    <td class="text-end">
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@user.Id"
                                              onsubmit="return confirm('Удалить пользователя @user.Username и все его видео?');"
                                              style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-action-danger-glass btn-sm">
                                                <i class="bi bi-trash me-1"></i>Удалить
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>