<!DOCTYPE html>
<html lang="ru" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - karaoke.platform</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    
    <!-- Outfit & Inter Fonts + Bootstrap Icons CDNs -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;700&family=Inter:wght@300;400;600;800&family=Lobster&family=Montserrat:wght@400;700;800&family=Outfit:wght@400;600;800&family=Oswald:wght@400;700&family=Pacifico&family=Rubik:wght@400;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/KaraokePlatform.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark border-bottom border-light-subtle py-3 bg-transparent">
            <div class="container">
                <a class="navbar-brand fw-bold text-white d-flex align-items-center gap-2" asp-page="/Index" style="font-size: 1.5rem; letter-spacing: -0.5px;">
                    <span class="bg-primary bg-opacity-25 p-2 rounded-3 text-primary d-inline-flex" style="box-shadow: 0 0 15px rgba(168, 85, 247, 0.4);"><i class="bi bi-music-note-list"></i></span>
                    <span>karaoke.platform</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white-50" asp-page="/Dashboard">Главная</a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-3 ms-auto">
                        <!-- Universal Theme Switcher Button -->
                        <button type="button" class="btn btn-sm btn-outline-light rounded-pill px-3 py-1 bg-transparent border-opacity-25" id="themeToggleBtn" style="border: 1px solid rgba(255,255,255,0.25);">
                            <i class="bi bi-sun-fill" id="themeToggleIcon"></i>
                        </button>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <span class="text-white-50 small d-none d-md-inline">Вы вошли как: <strong class="text-white">@User.Identity.Name</strong></span>
                            
                            @if (User.IsInRole("Admin"))
                            {
                                <button type="button" class="btn btn-sm btn-outline-light rounded-pill px-3 py-1 bg-transparent border-opacity-25" id="adminSidebarToggle" style="border: 1px solid rgba(255,255,255,0.25);">
                                    <i class="bi bi-gear-fill me-1"></i> Панель управления
                                </button>
                            }

                            <form method="post" asp-page="/Dashboard" asp-page-handler="Logout" class="m-0">
                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3 py-1">
                                    Выйти
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top border-light-subtle footer text-white-50 mt-5 py-3">
        <div class="container text-center small">
            &copy; 2026 - karaoke.platform
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
    {
        <!-- Admin Sidebar Overlay Backdrop -->
        <div id="adminSidebarBackdrop" class="admin-sidebar-backdrop"></div>

        <!-- Admin Sidebar Panel -->
        <div id="adminSidebar" class="admin-sidebar glass-panel">
            <!-- Token generator to guarantee verification checks on all child pages -->
            @Html.AntiForgeryToken()

            <div class="d-flex align-items-center justify-content-between mb-4 border-bottom border-light-subtle pb-3">
                <h4 class="fw-bold m-0 text-white"><i class="bi bi-shield-lock text-primary me-2"></i>Панель управления</h4>
                <button type="button" class="btn-close btn-close-white" id="adminSidebarClose" aria-label="Close"></button>
            </div>

            <!-- Tabs Navigation -->
            <ul class="nav nav-tabs border-light-subtle mb-3" id="adminTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="monitoring-tab" data-bs-toggle="tab" data-bs-target="#monitoring-content" type="button" role="tab">Мониторинг</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="queue-tab" data-bs-toggle="tab" data-bs-target="#queue-content" type="button" role="tab">Очередь</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="users-tab" data-bs-toggle="tab" data-bs-target="#users-content" type="button" role="tab">Пользователи</button>
                </li>
            </ul>

            <!-- Tab Content -->
            <div class="tab-content text-white" id="adminTabsContent">
                <!-- Monitoring Tab -->
                <div class="tab-pane fade show active" id="monitoring-content" role="tabpanel">
                    <h6 class="text-white-50 small fw-bold text-uppercase mb-3">Загрузка системы (ИИ обработка)</h6>
                    
                    <div class="mb-4">
                        <div class="d-flex justify-content-between mb-1 small">
                            <span>Нагрузка CPU</span>
                            <span id="cpuLoadText" class="text-info fw-bold">24%</span>
                        </div>
                        <svg viewBox="0 0 300 60" class="neon-graph" id="cpuGraph">
                            <path d="M 0 50 L 50 45 L 100 48 L 150 30 L 200 40 L 250 25 L 300 35" fill="none" stroke="#0dcaf0" stroke-width="2" />
                        </svg>
                    </div>

                    <div class="mb-4">
                        <div class="d-flex justify-content-between mb-1 small">
                            <span>Нагрузка GPU</span>
                            <span id="gpuLoadText" class="text-primary fw-bold">42%</span>
                        </div>
                        <svg viewBox="0 0 300 60" class="neon-graph" id="gpuGraph">
                            <path d="M 0 55 L 50 48 L 100 35 L 150 20 L 200 45 L 250 15 L 300 25" fill="none" stroke="#a855f7" stroke-width="2" />
                        </svg>
                    </div>
                </div>

                <!-- Task Queue Tab -->
                <div class="tab-pane fade" id="queue-content" role="tabpanel">
                    <h6 class="text-white-50 small fw-bold text-uppercase mb-3">Активные задачи</h6>
                    <div id="sidebarQueueContainer" class="vstack gap-3" style="max-height: 50vh; overflow-y: auto;">
                        <div class="text-center py-4 text-muted small">Загрузка очереди...</div>
                    </div>
                </div>

                <!-- Users Tab -->
                <div class="tab-pane fade" id="users-content" role="tabpanel">
                    <!-- Create User Form Card -->
                    <h6 class="text-white-50 small fw-bold text-uppercase mb-2">Создать пользователя</h6>
                    <form id="sidebarCreateUserForm" class="mb-4 p-3 rounded-4 border border-light-subtle" style="background: rgba(255,255,255,0.02);">
                        <div class="mb-2">
                            <label class="form-label small text-white-50 mb-1">Имя пользователя</label>
                            <input type="text" id="createUserUsername" class="form-control form-control-sm" required autocomplete="off" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label small text-white-50 mb-1">Пароль</label>
                            <input type="password" id="createUserPassword" class="form-control form-control-sm" required autocomplete="off" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label small text-white-50 mb-1">Роль</label>
                            <select id="createUserRole" class="form-select form-select-sm">
                                <option value="User">Пользователь</option>
                                <option value="Admin">Администратор</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm rounded-pill w-100 fw-bold mt-2">Создать</button>
                    </form>

                    <!-- Users list heading -->
                    <h6 class="text-white-50 small fw-bold text-uppercase mb-3">Список пользователей</h6>
                    <div id="sidebarUsersContainer" class="vstack gap-2" style="max-height: 40vh; overflow-y: auto;">
                        <div class="text-center py-4 text-muted small">Загрузка пользователей...</div>
                    </div>
                </div>
            </div>
        </div>

        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const toggleBtn = document.getElementById('adminSidebarToggle');
                const sidebar = document.getElementById('adminSidebar');
                const backdrop = document.getElementById('adminSidebarBackdrop');
                const closeBtn = document.getElementById('adminSidebarClose');

                let adminPollingInterval = null;

                if (toggleBtn && sidebar && backdrop) {
                    toggleBtn.addEventListener('click', () => {
                        sidebar.classList.add('active');
                        backdrop.classList.add('active');
                        fetchAdminData();
                        
                        // Start polling every 3 seconds when sidebar is open
                        if (!adminPollingInterval) {
                            adminPollingInterval = setInterval(fetchAdminData, 3000);
                        }
                    });

                    const closeSidebar = () => {
                        sidebar.classList.remove('active');
                        backdrop.classList.remove('active');
                        
                        // Stop polling when sidebar is closed
                        if (adminPollingInterval) {
                            clearInterval(adminPollingInterval);
                            adminPollingInterval = null;
                        }
                    };

                    closeBtn.addEventListener('click', closeSidebar);
                    backdrop.addEventListener('click', closeSidebar);
                }

                const tabButtons = document.querySelectorAll('#adminTabs button');
                tabButtons.forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        tabButtons.forEach(b => b.classList.remove('active'));
                        btn.classList.add('active');
                    });
                });

                // User Creation Form handler
                const createUserForm = document.getElementById('sidebarCreateUserForm');
                if (createUserForm) {
                    createUserForm.addEventListener('submit', async (e) => {
                        e.preventDefault();
                        const username = document.getElementById('createUserUsername').value.trim();
                        const password = document.getElementById('createUserPassword').value.trim();
                        const role = document.getElementById('createUserRole').value;
                        const antiafsToken = document.querySelector('input[name="__RequestVerificationToken"]').value;

                        try {
                            const response = await fetch('/Dashboard?handler=CreateUser', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json',
                                    'RequestVerificationToken': antiafsToken
                                },
                                body: JSON.stringify({ username, password, role })
                            });

                            if (response.ok) {
                                alert('Пользователь успешно создан!');
                                createUserForm.reset();
                                await fetchAdminData();
                            } else {
                                const errMsg = await response.text();
                                alert('Ошибка: ' + (errMsg || 'Не удалось создать пользователя.'));
                            }
                        } catch (err) {
                            console.error(err);
                            alert('Ошибка соединения с сервером.');
                        }
                    });
                }

                function updateNeonGraphs(cpuVal, gpuVal) {
                    const cpuText = document.getElementById('cpuLoadText');
                    const gpuText = document.getElementById('gpuLoadText');
                    
                    if (cpuText && gpuText) {
                        cpuText.innerText = cpuVal + '%';
                        gpuText.innerText = gpuVal + '%';

                        updateSvgPath('cpuGraph', cpuVal);
                        updateSvgPath('gpuGraph', gpuVal);
                    }
                }

                function updateSvgPath(graphId, newVal) {
                    const graph = document.getElementById(graphId);
                    if (!graph) return;
                    const path = graph.querySelector('path');
                    if (!path) return;

                    const d = path.getAttribute('d');
                    const points = d.substring(2).split(' L ');
                    
                    const nextPoints = points.slice(1);
                    const nextX = 300;
                    const nextY = 60 - (newVal * 0.5);

                    let newD = 'M ';
                    for (let i = 0; i < nextPoints.length; i++) {
                        const parts = nextPoints[i].split(' ');
                        const x = i * 50;
                        const y = parts[1];
                        newD += `${x} ${y} L `;
                    }
                    newD += `${nextX} ${nextY}`;
                    path.setAttribute('d', newD);
                }

                async function fetchAdminData() {
                    try {
                        const response = await fetch('/Dashboard?handler=AdminData');
                        if (response.ok) {
                            const data = await response.json();
                            renderAdminSidebar(data);
                            if (typeof data.cpuUsage !== 'undefined' && typeof data.gpuUsage !== 'undefined') {
                                updateNeonGraphs(data.cpuUsage, data.gpuUsage);
                            }
                        }
                    } catch (e) {
                        console.error('Error fetching admin data:', e);
                    }
                }

                function renderAdminSidebar(data) {
                    const queueContainer = document.getElementById('sidebarQueueContainer');
                    if (queueContainer) {
                        if (data.tasks.length === 0) {
                            queueContainer.innerHTML = `<div class="text-center py-4 text-muted small">Очередь задач пуста.</div>`;
                        } else {
                            queueContainer.innerHTML = data.tasks.map(t => {
                                let statusText = 'В очереди';
                                let statusClass = 'text-muted';
                                let progressPercent = 0;

                                if (t.status === 0) { // InQueue
                                    statusText = 'В очереди';
                                    statusClass = 'text-white-50';
                                    progressPercent = 5;
                                } else if (t.status === 1) { // Processing
                                    statusText = 'Обработка';
                                    statusClass = 'text-warning';
                                    progressPercent = t.progress > 0 ? t.progress : 45;
                                } else if (t.status === 2) { // AwaitingReview
                                    statusText = 'Ожидает проверки';
                                    statusClass = 'text-info';
                                    progressPercent = 80;
                                } else if (t.status === 3) { // ReadyToRender
                                    statusText = 'Рендеринг';
                                    statusClass = 'text-primary';
                                    progressPercent = 90;
                                } else if (t.status === 4) { // Completed
                                    statusText = 'Готово';
                                    statusClass = 'text-success';
                                    progressPercent = 100;
                                } else if (t.status === 5) { // Failed
                                    statusText = 'Ошибка';
                                    statusClass = 'text-danger';
                                    progressPercent = 100;
                                }

                                return `
                                    <div class="sidebar-task-card d-flex align-items-center justify-content-between mb-2">
                                        <div class="text-truncate me-2" style="max-width: 70%">
                                            <div class="small fw-bold text-white text-truncate" title="${t.originalFileName}">${t.originalFileName}</div>
                                            <div class="small ${statusClass}">${statusText}</div>
                                        </div>
                                        <div class="position-relative d-inline-flex">
                                            <svg class="circular-progress" width="36" height="36" viewBox="0 0 36 36">
                                                <circle cx="18" cy="18" r="16" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="3"></circle>
                                                <circle cx="18" cy="18" r="16" fill="none" stroke="#a855f7" stroke-width="3" stroke-dasharray="100" stroke-dashoffset="${100 - progressPercent}" stroke-linecap="round"></circle>
                                            </svg>
                                            <span class="position-absolute top-50 start-50 translate-middle text-white" style="font-size: 0.7rem; font-weight: bold">${progressPercent}%</span>
                                        </div>
                                    </div>
                                `;
                            }).join('');
                        }
                    }

                    const usersContainer = document.getElementById('sidebarUsersContainer');
                    if (usersContainer) {
                        if (data.users.length === 0) {
                            usersContainer.innerHTML = `<div class="text-center py-4 text-muted small">Нет пользователей.</div>`;
                        } else {
                            usersContainer.innerHTML = data.users.map(u => `
                                <div class="sidebar-task-card d-flex align-items-center justify-content-between p-2.5 mb-1">
                                    <div class="fw-semibold text-white text-truncate me-2" style="font-size: 0.85rem">${u.username}</div>
                                    <span class="badge ${u.role === 1 ? 'badge-admin-glass' : 'badge-user-glass'} rounded-pill px-2.5 py-1 text-uppercase" style="font-size: 0.6rem">${u.role === 1 ? 'Admin' : 'User'}</span>
                                </div>
                            `).join('');
                        }
                    }
                }
            });
        </script>
    }

    <!-- Universal Light/Dark Theme Switcher JS handler -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme') || 'dark';
            document.documentElement.setAttribute('data-theme', savedTheme);
            updateThemeToggleUI(savedTheme);

            const themeToggleBtn = document.getElementById('themeToggleBtn');
            if (themeToggleBtn) {
                themeToggleBtn.addEventListener('click', () => {
                    const currentTheme = document.documentElement.getAttribute('data-theme') || 'dark';
                    const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
                    document.documentElement.setAttribute('data-theme', newTheme);
                    localStorage.setItem('theme', newTheme);
                    updateThemeToggleUI(newTheme);
                });
            }

            function updateThemeToggleUI(theme) {
                const icon = document.getElementById('themeToggleIcon');
                if (icon) {
                    if (theme === 'light') {
                        icon.className = 'bi bi-moon-stars-fill';
                    } else {
                        icon.className = 'bi bi-sun-fill';
                    }
                }
            }
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
