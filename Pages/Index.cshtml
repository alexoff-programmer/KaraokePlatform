@page
@model IndexModel
@{
    ViewData["Title"] = "Вход в систему";
}

<div class="row justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="col-md-4">
        <div class="card glass-panel p-4 text-white rounded-4 border-0">
            <div class="card-body p-3">
                <h2 class="text-center mb-1 font-weight-bold text-white"><i class="bi bi-music-note-list me-2" style="color: #a855f7;"></i>karaoke.platform</h2>
                <p class="text-white-50 text-center small mb-4">Авторизуйтесь для доступа к платформе</p>

                @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                {
                    <div class="alert alert-success small" role="alert">
                        @Model.SuccessMessage
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger" role="alert" style="font-size: 0.85rem;">
                        @Model.ErrorMessage
                    </div>
                }

                <form method="post">
                    <div class="mb-3">
                        <label asp-for="Username" class="form-label text-white-50 small">Имя пользователя</label>
                        <input asp-for="Username" class="form-control form-control-lg bg-transparent text-white"
                               autocomplete="username" required />
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label text-white-50 small">Пароль</label>
                        <input asp-for="Password" type="password" class="form-control form-control-lg bg-transparent text-white"
                               autocomplete="current-password" required />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 btn-generate-glowing rounded-pill py-2.5">Войти</button>
                </form>
            </div>
        </div>
    </div>
</div>