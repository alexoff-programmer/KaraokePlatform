@page
@using KaraokePlatform.Data.Entities
@using System.IO
@model DashboardModel
@{
    ViewData["Title"] = "Личный кабинет";
}

<div class="container py-5">
    <div class="row mb-5">
        <div class="col-lg-6">
            <h1 class="h2 fw-bold text-dark">Добро пожаловать, @User.Identity?.Name</h1>
            <p class="text-muted">Ваша личная студия обработки аудио в караоке-видео.</p>
        </div>
        @* Кнопка отображается только если у пользователя есть роль Admin *@
        @if (User.IsInRole("Admin"))
        {
            <div class="col-md-4 text-md-end">
                <a asp-page="/Admin/ManageUsers" class="btn btn-outline-danger btn-lg fw-bold rounded-3 shadow-sm">
                    <i class="bi bi-shield-lock-fill me-2"></i>Панель администратора
                </a>
            </div>
        }
    </div>

    <div class="row g-4">
        @* Форма загрузки *@
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm p-4 rounded-4">
                <h5 class="fw-bold mb-3">Загрузить трек</h5>
                <form method="post" asp-page-handler="Upload" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label class="form-label text-muted small">Файл MP3</label>
                        <input asp-for="UploadedAudio" class="form-control form-control-lg" type="file" accept=".mp3"
                               required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small">Фоновое изображение (необязательно)</label>
                        <input asp-for="UploadedBackground" class="form-control form-control-lg" type="file"
                               accept=".jpg,.jpeg,.png" />
                        <div class="form-text small text-muted">Если не выбрать, фон останется черным.</div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-muted small">Язык</label>
                        <select asp-for="SelectedLanguage" class="form-select form-select-lg">
                            <option value="auto">🌍 Автоматически</option>
                            <option value="ru">🇷🇺 Русский</option>
                            <option value="en">🇺🇸 Английский</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold">Начать обработку</button>
                </form>
            </div>
        </div>

        @* Таблица задач *@
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <h5 class="card-title mb-4 fw-bold">Мои генерации</h5>

                    @if (!Model.UserTasks.Any())
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-music-note-beamed display-4 mb-3 d-block text-secondary opacity-50"></i>
                            <p class="mb-0">Вы еще не загрузили ни одного трека.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            @* Жесткая разметка таблицы fixed гарантирует, что колонки не будут сжиматься или дергаться *@
                            <table class="table table-hover align-middle" style="table-layout: fixed; width: 100%;">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 30%; font-size: 0.85rem;" class="text-secondary">Файл</th>
                                        <th style="width: 20%; font-size: 0.85rem;" class="text-secondary">Дата</th>
                                        <th style="width: 35%; font-size: 0.85rem;" class="text-secondary">Статус</th>
                                        <th style="width: 15%; font-size: 0.85rem;" class="text-secondary text-end">
                                            Результат</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var task in Model.UserTasks)
                                        {
                                            <tr id="task-@task.Id">
                                                <td class="fw-bold text-truncate" title="@task.OriginalFileName">
                                                    @task.OriginalFileName
                                                </td>
                                                <td class="small text-muted">@task.CreatedAt.ToLocalTime().ToString("g")</td>
                                                <td class="task-status">
                                                    @if (task.Status == KaraokeTaskStatus.InQueue)
                                                    {
                                                        <span class="text-secondary small"><i class="bi bi-hourglass-split me-1"></i>В
                                                            очереди</span>
                                                        }
                                                else if (task.Status == KaraokeTaskStatus.Processing)
                                                        {
                                                            @* Компактный и красивый контейнер с мини-баром *@
                                                            <div class="processing-container">
                                                                <div class="d-flex align-items-center text-warning small mb-1">
                                                                    <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                                                                    <span class="processing-text">Обработка...</span>
                                                                </div>
                                                                <div class="progress" style="height: 4px; background-color: #f0f0f0;">
                                                                    <div class="progress-bar progress-bar-striped progress-bar-animated bg-warning"
                                                                         role="progressbar" style="width: 10%"></div>
                                                                </div>
                                                            </div>
                                                        }
                                                        else if (task.Status == KaraokeTaskStatus.Completed)
                                                        {
                                                            <span class="text-success small"><i
                                                                class="bi bi-check-circle-fill me-1"></i>Готово</span>
                                                            }
                                                else if (task.Status == KaraokeTaskStatus.Failed)
                                                            {
                                                                <span class="text-danger small"
                                                                      title="@(string.IsNullOrEmpty(task.ErrorMessage) ? "Ошибка обработки" : task.ErrorMessage)">
                                                                    <i class="bi bi-exclamation-triangle-fill me-1"></i>Ошибка
                                                                </span>
                                                            }
                                                        </td>
                                                        <td class="task-action text-end">
                                                            @if (task.Status == KaraokeTaskStatus.Completed &&
                                    !string.IsNullOrEmpty(task.VideoFilePath))
                                                            {
                                                                @* Берем оригинальное имя, убираем старое расширение .mp3 (если есть) и
                                                                    добавляем .mp4 *@
                                                                var downloadName =
                                                                System.IO.Path.GetFileNameWithoutExtension(task.OriginalFileName) +
                                                                ".mp4";

                                                                <a href="/@task.VideoFilePath"
                                                                   class="btn btn-sm btn-outline-success rounded-3 px-3"
                                                                   download="@downloadName">
                                                                    <i class="bi bi-download me-1"></i>MP4
                                                                </a>
                                                            }
                                                            else if (task.Status == KaraokeTaskStatus.Processing)
                                                            {
                                                                <button class="btn btn-sm btn-light rounded-3 text-muted" disabled><i
                                                                    class="bi bi-cpu"></i></button>
                                                                }
                                                else
                                                                {
                                                                    <button class="btn btn-sm btn-light rounded-3 text-muted" disabled><i
                                                                        class="bi bi-dash-lg"></i></button>
                                                                    }
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    @section Scripts {
                        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
                        @* Подключаем Bootstrap Icons для интерфейса таблиц *@
                        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

                        <script>
                            const connection = new signalR.HubConnectionBuilder()
                            .withUrl("/notificationHub")
                            .withAutomaticReconnect()
                            .build();

                            connection.on("UpdateTaskStatus", function (taskId, status, videoUrl) {
                            const row = document.getElementById("task-" + taskId);
                            if (!row) return;

                            const statusCell = row.querySelector(".task-status");
                            const actionCell = row.querySelector(".task-action");

                            if (status.startsWith("Processing")) {
                            let container = statusCell.querySelector(".processing-container");

                            // Если задача только перешла из очереди ("InQueue") — строим чистую HTML структуру прогресса
                            if (!container) {
                            statusCell.innerHTML = `
                            <div class="processing-container">
                            <div class="d-flex align-items-center text-warning small mb-1">
                            <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                            <span class="processing-text">Обработка...</span>
                            </div>
                            <div class="progress" style="height: 4px; background-color: #f0f0f0;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated bg-warning" role="progressbar" style="width: 10%"></div>
                            </div>
                            </div>`;
                            container = statusCell.querySelector(".processing-container");
                            }

                            const textElement = container.querySelector(".processing-text");
                            const progressBar = container.querySelector(".progress-bar");

                            // Вытаскиваем числовое значение процентов регуляркой
                            const match = status.match(/\d+/);
                            const percent = match ? match[0] : "10";

                            // Определяем красивый подтекст (если бэкенд передал скобки, например: "(Сборка видео...)")
                            let textDescription = `Обработка: ${percent}%`;
                            if (status.includes("(")) {
                            const subPhase = status.substring(status.indexOf("(") + 1, status.indexOf(")"));
                            textDescription = `${subPhase} (${percent}%)`;
                            }

                            // Обновляем состояние атомарно: только текст и только ширину полосы (никакого изменения высоты строки!)
                            if (textElement) textElement.innerText = textDescription;
                            if (progressBar) progressBar.style.width = percent + "%";

                            actionCell.innerHTML = `<button class="btn btn-sm btn-light rounded-3 text-muted" disabled><i class="bi bi-cpu"></i></button>`;
                            }
                            else if (status === "Completed") {
                            statusCell.innerHTML = `<span class="text-success small"><i class="bi bi-check-circle-fill me-1"></i>Готово</span>`;

                            // Находим оригинальное имя файла из первой колонки текущей строки
                            const fileNameCell = row.querySelector("td.text-truncate");
                            let downloadName = "video.mp4";
                            if (fileNameCell) {
                            // Убираем расширение .mp3, если оно есть, и принудительно ставим .mp4
                            const originalName = fileNameCell.innerText.trim();
                            downloadName = originalName.replace(/\.[^/.]+$/, "") + ".mp4";
                            }

                            // Подставляем сформированное имя в атрибут download
                            actionCell.innerHTML = `<a href="/${videoUrl}" class="btn btn-sm btn-outline-success rounded-3 px-3" download="${downloadName}"><i class="bi bi-download me-1"></i>MP4</a>`;

                            row.classList.add("table-success");
                            setTimeout(() => row.classList.remove("table-success"), 2500);
                            }
                            else if (status === "Failed") {
                            statusCell.innerHTML = `<span class="text-danger small"><i class="bi bi-exclamation-triangle-fill me-1"></i>Ошибка</span>`;
                            actionCell.innerHTML = `<button class="btn btn-sm btn-light rounded-3 text-muted" disabled><i class="bi bi-dash-lg"></i></button>`;
                            }
                            });

                            connection.start().catch(function (err) {
                            return console.error(err.toString());
                            });
                        </script>
                    }