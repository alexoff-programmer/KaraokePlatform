@page
@using KaraokePlatform.Data.Entities
@model DashboardModel
@{
    ViewData["Title"] = "Личный кабинет";
}

<div class="container py-4">
    <div class="row mb-4 align-items-center">
        <div class="col">
            <h1 class="h3 text-secondary">Добро пожаловать, <span class="text-primary">@User.Identity?.Name</span>!</h1>
        </div>
        <div class="col-auto">
            @if (User.IsInRole("Admin"))
            {
                <a class="btn btn-outline-danger me-2" asp-page="/Admin/ManageUsers">Панель администратора</a>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
    }
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success" role="alert">@Model.SuccessMessage</div>
    }

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-body p-4">
                    <h5 class="card-title mb-3 font-weight-bold">Создать караоке</h5>
                    <p class="text-muted small">Загрузите аудиофайл трека в формате MP3. Система автоматически
                        распознает текст, создаст субтитры и сгенерирует вертикальное видео.</p>

                        <div class="card shadow-sm border-0 rounded-3">
                            <div class="card-body p-4">
                                <h5 class="card-title mb-3 font-weight-bold">Создать караоке</h5>
                                <p class="text-muted small">Загрузите аудиофайл трека в формате MP3. Система автоматически
                                    распознает текст, создаст субтитры и сгенерирует вертикальное видео.</p>

                                    <form method="post" asp-page-handler="Upload" enctype="multipart/form-data">
                                        <div class="mb-3">
                                            <label asp-for="UploadedAudio" class="form-label text-secondary small">Выберите .MP3
                                                файл</label>
                                                <input asp-for="UploadedAudio" class="form-control" type="file" accept=".mp3"
                                                       required />
                                            </div>

                                            <div class="mb-4">
                                                <label asp-for="SelectedLanguage" class="form-label text-secondary small">Язык
                                                    исполнения</label>
                                                    <select asp-for="SelectedLanguage" class="form-select">
                                                        <option value="auto">🌍 Определить автоматически (Auto)</option>
                                                        <option value="ru">🇷🇺 Русский</option>
                                                        <option value="en">🇺🇸 Английский</option>
                                                        <option value="es">🇪🇸 Испанский</option>
                                                        <option value="de">🇩🇪 Немецкий</option>
                                                    </select>
                                                </div>

                                                <button type="submit" class="btn btn-primary w-100 shadow-sm rounded-3">Отправить в
                                                    очередь</button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-lg-8">
                                        <div class="card shadow-sm border-0 rounded-3">
                                            <div class="card-body p-4">
                                                <h5 class="card-title mb-3 font-weight-bold">Мои генерации</h5>

                                                @if (!Model.UserTasks.Any())
                                                {
                                                    <div class="text-center py-4 text-muted">
                                                        <p class="mb-0">Вы еще не загрузили ни одного трека.</p>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="table-responsive">
                                                        <table class="table table-hover align-middle">
                                                            <thead class="table-light">
                                                                <tr>
                                                                    <th style="font-size: 0.85rem;" class="text-secondary">Файл</th>
                                                                    <th style="font-size: 0.85rem;" class="text-secondary">Дата</th>
                                                                    <th style="font-size: 0.85rem;" class="text-secondary">Статус</th>
                                                                    <th style="font-size: 0.85rem;" class="text-secondary">Результат</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var task in Model.UserTasks)
                                                                {
                                                                    <tr id="task-@task.Id">
                                                                        <td class="font-weight-bold">@task.OriginalFileName</td>
                                                                        <td class="small text-muted">@task.CreatedAt.ToLocalTime().ToString("g")
                                                                        </td>
                                                                        <td class="task-status">
                                                                            @if (task.Status == KaraokeTaskStatus.InQueue)
                                                                            {
                                                                                <span class="badge bg-secondary text-white rounded-pill px-2 py-1">В
                                                                                    очереди</span>
                                                                                }
                                                                            else if (task.Status == KaraokeTaskStatus.Processing)
                                                                                {
                                                                                    <span class="badge bg-warning text-dark rounded-pill px-2 py-1">
                                                                                        <span class="spinner-border spinner-border-sm me-1" role="status"
                                                                                              aria-hidden="true"></span>Обработка
                                                                                    </span>
                                                                                }
                                                                                else if (task.Status == KaraokeTaskStatus.Completed)
                                                                                {
                                                                                    <span
                                                                                    class="badge bg-success text-white rounded-pill px-2 py-1">Готово</span>
                                                                                }
                                                                                else if (task.Status == KaraokeTaskStatus.Failed)
                                                                                {
                                                                                    <span class="badge bg-danger text-white rounded-pill px-2 py-1"
                                                                                          title="@task.ErrorMessage">Ошибка</span>
                                                                                }
                                                                            </td>
                                                                            <td class="task-action">
                                                                                @if (task.Status == KaraokeTaskStatus.Completed &&
                                                    !string.IsNullOrEmpty(task.VideoFilePath))
                                                                                {
                                                                                    <a href="/@task.VideoFilePath"
                                                                                       class="btn btn-sm btn-outline-success rounded-3" download>Скачать
                                                                                        MP4</a>
                                                                                    }
                                                                            else
                                                                                    {
                                                                                        <button class="btn btn-sm btn-light rounded-3 text-muted"
                                                                                                disabled>Ожидание</button>
                                                                                    }
                                                                                </td>
                                                                            </tr>
                                                                        }
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    @section Scripts {
                                        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

                                        <script>
                                            // Настраиваем соединение с нашим эндпоинтом
                                            const connection = new signalR.HubConnectionBuilder()
                                            .withUrl("/notificationHub")
                                            .withAutomaticReconnect() // Авто-переподключение при обрыве сети
                                            .build();

                                            // Слушаем событие обновления статуса от сервера
                                            connection.on("UpdateTaskStatus", function (taskId, status, videoUrl) {
                                            // Ищем строку конкретной задачи в таблице
                                            const row = document.getElementById("task-" + taskId);
                                            if (!row) return; // Если строки нет на экране, игнорируем

                                            const statusCell = row.querySelector(".task-status");
                                            const actionCell = row.querySelector(".task-action");

                                            if (status === "Processing") {
                                            statusCell.innerHTML = `<span class="badge bg-warning text-dark rounded-pill px-2 py-1">
                                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>Обработка
                                            </span>`;
                                            }
                                            else if (status === "Completed") {
                                            statusCell.innerHTML = `<span class="badge bg-success text-white rounded-pill px-2 py-1">Готово</span>`;
                                            actionCell.innerHTML = `<a href="/${videoUrl}" class="btn btn-sm btn-outline-success rounded-3" download>Скачать MP4</a>`;

                                            // Красивый штрих: подсветим строку зеленым на секунду, сигнализируя готовность
                                            row.classList.add("table-success");
                                            setTimeout(() => row.classList.remove("table-success"), 2000);
                                            }
                                            else if (status === "Failed") {
                                            statusCell.innerHTML = `<span class="badge bg-danger text-white rounded-pill px-2 py-1">Ошибка</span>`;
                                            actionCell.innerHTML = `<button class="btn btn-sm btn-light rounded-3 text-muted" disabled>Ошибка</button>`;
                                            }
                                            });

                                            // Запускаем соединение
                                            connection.start().catch(function (err) {
                                            return console.error(err.toString());
                                            });
                                        </script>
                                    }