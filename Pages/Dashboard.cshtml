@page
@using KaraokePlatform.Data.Entities
@using System.IO
@model DashboardModel
@{
    ViewData["Title"] = "Личный кабинет";
}

<div class="container py-4">
    <!-- Success/Error Alert Bar -->
    @if (!string.IsNullOrEmpty(Model.SuccessMessage) || TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success border-0 shadow rounded-4 mb-4 bg-success bg-opacity-25 text-white" role="alert">
            <i class="bi bi-check-circle-fill me-2 text-success"></i>
            @(Model.SuccessMessage ?? TempData["SuccessMessage"])
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage) || TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger border-0 shadow rounded-4 mb-4 bg-danger bg-opacity-25 text-white" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2 text-danger"></i>
            @(Model.ErrorMessage ?? TempData["ErrorMessage"])
        </div>
    }

    <!-- Outer Form wrapping both Configurator and Preview to ensure proper tag helper nesting -->
    <form id="uploadForm" method="post" asp-page-handler="Upload" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" name="GeminiApiKey" id="dashboardGeminiApiKey" />
        <input type="hidden" name="AutoImproveEnabled" id="dashboardAutoImproveEnabled" />
        <input type="hidden" name="SelectedPresetBg" id="dashboardSelectedPresetBg" />

        <div class="row g-4 mb-5">
            <!-- Left Panel: Configurator Accordion (No h-100 to prevent layout collapse) -->
            <div class="col-lg-4">
                <div class="card glass-panel p-4">
                    <h5 class="fw-bold mb-3 text-white"><i class="bi bi-sliders me-2 text-primary"></i>Параметры
                        генерации</h5>
                        <div class="accordion accordion-flush" id="configuratorAccordion">
                            <!-- Accordion 1: Source Files -->
                            <div class="accordion-item bg-transparent">
                                <h2 class="accordion-header">
                                    <button class="accordion-button" type="button" data-bs-toggle="collapse"
                                            data-bs-target="#collapseFiles" aria-expanded="true">
                                        📁 Исходные файлы
                                    </button>
                                </h2>
                                <div id="collapseFiles" class="accordion-collapse collapse show"
                                     data-bs-parent="#configuratorAccordion">
                                    <div class="accordion-body pt-3 px-2">
                                        <div class="mb-3">
                                            <label class="form-label text-white-50 small">Аудиодорожка (MP3 / WAV)</label>
                                            <div class="dropzone-container" id="audioDropzone">
                                                <i class="bi bi-soundwave display-6 text-primary mb-2 d-block"></i>
                                                <span class="small d-block text-white" id="audioFilenameText">Перетащите
                                                    сюда mp3 или кликните</span>
                                                    <input asp-for="UploadedAudio"
                                                           class="position-absolute top-0 start-0 opacity-0 w-100 h-100"
                                                           style="cursor: pointer;" type="file" accept=".mp3" id="audioFileInput"
                                                           required />
                                                </div>
                                            </div>

                                            <div class="mb-3">
                                                <label class="form-label text-white-50 small">Фоновое изображение</label>
                                                <div class="dropzone-container mb-2" id="bgDropzone">
                                                    <i class="bi bi-image display-6 text-info mb-2 d-block"></i>
                                                    <span class="small d-block text-white" id="bgFilenameText">Загрузить
                                                        изображение или видео</span>
                                                        <input asp-for="UploadedBackground"
                                                               class="position-absolute top-0 start-0 opacity-0 w-100 h-100"
                                                               style="cursor: pointer;" type="file" accept=".jpg,.jpeg,.png"
                                                               id="bgFileInput" />
                                                    </div>
                                                    <button type="button" class="btn btn-gallery-adaptive btn-sm w-100 mt-2"
                                                            data-bs-toggle="modal" data-bs-target="#presetGalleryModal">
                                                        <i class="bi bi-images me-1"></i> Выбрать из галереи ИИ
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Accordion 2: Generation Settings -->
                                    <div class="accordion-item bg-transparent">
                                        <h2 class="accordion-header">
                                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                                                    data-bs-target="#collapseSettings" aria-expanded="false">
                                                ⚙️ Настройки видео
                                            </button>
                                        </h2>
                                        <div id="collapseSettings" class="accordion-collapse collapse"
                                             data-bs-parent="#configuratorAccordion">
                                            <div class="accordion-body pt-3 px-2">
                                                <div class="mb-3">
                                                    <label class="form-label text-white-50 small">Язык трека</label>
                                                    <select asp-for="SelectedLanguage" id="configLanguage" class="form-select">
                                                        <option value="auto">🌍 Автоматически</option>
                                                        <option value="ru">🇷🇺 Русский</option>
                                                        <option value="en">🇺🇸 Английский</option>
                                                    </select>
                                                </div>

                                                <div class="mb-3">
                                                    <label class="form-label text-white-50 small">Качество разделения вокала</label>
                                                    <select asp-for="SelectedQuality" id="configQuality" class="form-select">
                                                        <option value="low">Низкое (MDX-Net)</option>
                                                        <option value="medium">Среднее (MDX-Net)</option>
                                                        <option value="high">Высокое (BS-Roformer)</option>
                                                    </select>
                                                </div>

                                                <div class="mb-3">
                                                    <label class="form-label text-white-50 small">Шрифт караоке</label>
                                                    <select asp-for="SubtitleFont" id="configFont" class="form-select">
                                                        <option value="Inter">Inter (Строгий, кириллица)</option>
                                                        <option value="Montserrat">Montserrat (Геометрический, кириллица)</option>
                                                        <option value="Oswald">Oswald (Узкий / Жирный, кириллица)</option>
                                                        <option value="Rubik">Rubik (Дружелюбный округлый, кириллица)</option>
                                                        <option value="Comfortaa">Comfortaa (Стильный округлый, кириллица)</option>
                                                        <option value="Lobster">Lobster (Винтажный курсив, кириллица)</option>
                                                        <option value="Pacifico">Pacifico (Прикольный рукописный, кириллица)</option>
                                                        <option value="Outfit">Outfit (Премиум, только латиница)</option>
                                                    </select>
                                                </div>

                                                <div class="row g-3 mb-3">
                                                    <div class="col-6">
                                                        <label class="form-label text-white-50 small d-block">Цвет текста</label>
                                                        <div class="d-flex align-items-center gap-2">
                                                            <div class="color-picker-wrapper">
                                                                <input type="color" asp-for="PrimaryColor" id="configPrimaryColor" class="color-picker-input" />
                                                                <div class="color-picker-wheel" id="configPrimaryColorWheel"></div>
                                                            </div>
                                                            <span class="text-white-50 small fw-mono" id="primaryColorHex">#FFFFFF</span>
                                                        </div>
                                                    </div>
                                                    <div class="col-6">
                                                        <label class="form-label text-white-50 small d-block">Цвет закраски</label>
                                                        <div class="d-flex align-items-center gap-2">
                                                            <div class="color-picker-wrapper">
                                                                <input type="color" asp-for="SecondaryColor" id="configSecondaryColor" class="color-picker-input" />
                                                                <div class="color-picker-wheel" id="configSecondaryColorWheel"></div>
                                                            </div>
                                                            <span class="text-white-50 small fw-mono" id="secondaryColorHex">#A855F7</span>
                                                        </div>
                                                    </div>
                                                </div>

                                                    <div class="mb-3">
                                                        <label class="form-label text-white-50 small">Формат видео</label>
                                                        <select asp-for="VideoFormat" id="configVideoFormat" class="form-select">
                                                            <option value="portrait">📱 Вертикальный (1080×1920)</option>
                                                            <option value="landscape">🖥️ Горизонтальный (1920×1080)</option>
                                                        </select>
                                                    </div>

                                                    <div class="form-check form-switch py-2 mb-2">
                                                        <input asp-for="RemoveVocal" class="form-check-input" type="checkbox"
                                                               role="switch" id="removeVocalSwitch" checked>
                                                        <label class="form-check-label text-white small" for="removeVocalSwitch">Удалить
                                                            вокал ИИ</label>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Accordion 3: Gemini config -->
                                            <div class="accordion-item bg-transparent">
                                                <h2 class="accordion-header">
                                                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                                                            data-bs-target="#collapseGemini" aria-expanded="false">
                                                        ✨ Настройки Gemini ИИ
                                                    </button>
                                                </h2>
                                                <div id="collapseGemini" class="accordion-collapse collapse"
                                                     data-bs-parent="#configuratorAccordion">
                                                    <div class="accordion-body pt-3 px-2">
                                                        <p class="small text-white-50 mb-3" id="geminiStatusLabel">Статус: Выключено (нет
                                                            API ключа)</p>
                                                            <button type="button" class="btn btn-outline-primary btn-sm rounded-pill w-100"
                                                                    data-bs-toggle="modal" data-bs-target="#geminiConfigModal">
                                                                <i class="bi bi-gear-fill me-1"></i> Конфигурация Gemini
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Center Column: Interactive Preview (Aspect ratio constraints to prevent overlap) -->
                                    <div class="col-lg-8">
                                        <div class="card glass-panel p-4 d-flex flex-column justify-content-between">
                                            <h5 class="fw-bold mb-3 text-white"><i class="bi bi-eye me-2 text-info"></i>Интерактивное превью
                                                караоке</h5>

                                                <div class="player-preview-container mb-4 d-flex align-items-center justify-content-center">
                                                    <img src="/images/presets/preset_cyberpunk.png" id="playerBgImage"
                                                         class="player-preview-bg preset-card-cyberpunk" />
                                                    <div class="player-preview-overlay">
                                                        <div class="preview-subtitle-line" id="previewSubLine1">
                                                            <span class="preview-first-word" style="font-weight: 800;">Я люблю эт</span>от красивый караоке плеер
                                                        </div>
                                                    </div>
                                                </div>

                                                <button type="submit" id="btnGenerateSubmit"
                                                        class="btn btn-primary btn-lg btn-generate-glowing w-100 py-3 fw-bold rounded-pill text-uppercase">
                                                    <i class="bi bi-play-circle-fill me-2"></i>Сгенерировать караоке видео
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </form>

                                <!-- Active Generations Card -->
                                <div class="card glass-panel p-4 rounded-4 mt-4">
                                    <h5 class="fw-bold mb-4"><i class="bi bi-grid-3x3-gap me-2" style="color: #a855f7;"></i>Мои генерации</h5>

                                    @if (!Model.UserTasks.Any())
                                    {
                                        <div class="text-center py-5">
                                            <i class="bi bi-music-note-beamed display-4 mb-3 d-block text-secondary opacity-50"></i>
                                            <p class="mb-0 no-tracks-placeholder">Вы еще не загрузили ни одного трека.</p>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="vstack gap-3" id="userTasksContainer">
                                            @foreach (var task in Model.UserTasks)
                                            {
                                                <div class="sidebar-task-card d-flex flex-column flex-md-row align-items-md-center justify-content-between p-3 gap-3"
                                                     id="task-@task.Id">
                                                    <div class="d-flex align-items-center gap-3 text-truncate" style="flex: 1; min-width: 0;">
                                                        <div class="position-relative d-inline-flex flex-shrink-0">
                                                            @{
                                                                int progressPercent = 0;
                                                                if (task.Status == KaraokeTaskStatus.InQueue) progressPercent = 5;
                                                                else if (task.Status == KaraokeTaskStatus.Processing) progressPercent = task.Progress > 0 ?
                                                    task.Progress : 10;
                                                                else if (task.Status == KaraokeTaskStatus.AwaitingReview) progressPercent = 80;
                                                                else if (task.Status == KaraokeTaskStatus.ReadyToRender) progressPercent = 90;
                                                                else if (task.Status == KaraokeTaskStatus.Completed) progressPercent = 100;
                                                                else if (task.Status == KaraokeTaskStatus.Failed) progressPercent = 100;
                                                            }
                                                            <svg class="circular-progress" width="40" height="40" viewBox="0 0 36 36">
                                                                <circle cx="18" cy="18" r="16" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="3">
                                                                </circle>
                                                                <circle cx="18" cy="18" r="16" fill="none" stroke="#a855f7" stroke-width="3"
                                                                        stroke-dasharray="100" stroke-dashoffset="@(100 - progressPercent)"
                                                                        stroke-linecap="round"></circle>
                                                            </svg>
                                                            <span
                                                            class="position-absolute top-50 start-50 translate-middle text-white task-progress-percent"
                                                            style="font-size: 0.75rem; font-weight: bold">@progressPercent%</span>
                                                        </div>
                                                        <div class="text-truncate" style="min-width: 0;">
                                                            <div class="fw-bold text-white text-truncate mb-1" title="@task.OriginalFileName">
                                                                @task.OriginalFileName</div>
                                                                <div class="d-flex align-items-center gap-2 small">
                                                                    <span class="text-white-50">@task.CreatedAt.ToLocalTime().ToString("g")</span>
                                                                    <span class="text-white-50 opacity-25">|</span>
                                                                    <span class="task-status-text">
                                                                        @if (task.Status == KaraokeTaskStatus.InQueue)
                                                                        {
                                                                            <span class="text-white-50"><i class="bi bi-hourglass-split me-1"></i>В очереди</span>
                                                                        }
                                                                        else if (task.Status == KaraokeTaskStatus.Processing)
                                                                        {
                                                                            <span class="text-warning"><i
                                                                                class="spinner-border spinner-border-sm me-1 flex-shrink-0"
                                                                                style="width:0.8rem;height:0.8rem;" role="status"></i>Обработка</span>
                                                                            }
                                        else if (task.Status == KaraokeTaskStatus.AwaitingReview)
                                                                            {
                                                                                <span class="text-info"><i class="bi bi-pencil-square me-1"></i>Ожидает проверки</span>
                                                                            }
                                                                            else if (task.Status == KaraokeTaskStatus.ReadyToRender)
                                                                            {
                                                                                <span class="text-primary"><i
                                                                                    class="bi bi-gear-wide-connected me-1 animate-spin"></i>Сборка видео...</span>
                                                                                }
                                        else if (task.Status == KaraokeTaskStatus.Completed)
                                                                                {
                                                                                    <span class="text-success"><i class="bi bi-check-circle-fill me-1"></i>Готово</span>
                                                                                }
                                                                                else if (task.Status == KaraokeTaskStatus.Failed)
                                                                                {
                                                                                    <span class="text-danger"
                                                                                          title="@(string.IsNullOrEmpty(task.ErrorMessage) ? "Ошибка обработки" : task.ErrorMessage)"><i
                                                                                        class="bi bi-exclamation-triangle-fill me-1"></i>Ошибка</span>
                                                                                    }
                                                                                </span>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="task-action d-flex align-items-center gap-2 justify-content-end">
                                                                        @if (task.Status == KaraokeTaskStatus.Completed && !string.IsNullOrEmpty(task.VideoFilePath))
                                                                        {
                                                                            var downloadName = System.IO.Path.GetFileNameWithoutExtension(task.OriginalFileName) + ".mp4";
                                                                            <a href="/@task.VideoFilePath" class="btn btn-action-glass" download="@downloadName">
                                                                                <i class="bi bi-download me-1"></i>MP4
                                                                            </a>
                                                                            <a href="/EditSubtitles?taskId=@task.Id" class="btn btn-action-glass"
                                                                               style="color: #ffc107 !important; border-color: rgba(255, 193, 7, 0.3) !important;">
                                                                                <i class="bi bi-pencil-square me-1"></i>Изменить
                                                                            </a>
                                                                        }
                                                                        else if (task.Status == KaraokeTaskStatus.AwaitingReview)
                                                                        {
                                                                            <a href="/EditSubtitles?taskId=@task.Id" class="btn btn-action-glass"
                                                                               style="color: #ffc107 !important; border-color: rgba(255, 193, 7, 0.3) !important;">
                                                                                <i class="bi bi-keyboard me-1"></i>Текст
                                                                            </a>
                                                                        }
                                                                        else if (task.Status == KaraokeTaskStatus.Processing)
                                                                        {
                                                                            <button class="btn btn-action-glass" disabled>
                                                                                <i class="bi bi-cpu"></i>
                                                                            </button>
                                                                        }
                                                                        else
                                                                        {
                                                                            <button class="btn btn-action-glass" disabled>
                                                                                <i class="bi bi-dash-lg"></i>
                                                                            </button>
                                                                        }

                                                                        <form method="post" action="/Dashboard?handler=Delete&taskId=@task.Id"
                                                                              onsubmit="return confirm('Вы уверены, что хотите прервать обработку и удалить файлы?');"
                                                                              class="d-inline m-0">
                                                                            @Html.AntiForgeryToken()
                                                                            <button type="submit" class="btn btn-action-danger-glass"><i class="bi bi-trash"></i></button>
                                                                        </form>
                                                                    </div>
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            </div>

                                            <!-- Modal 1: Neural Background presets Gallery -->
                                            <div class="modal fade" id="presetGalleryModal" tabindex="-1" aria-labelledby="galleryLabel" aria-hidden="true">
                                                <div class="modal-dialog modal-dialog-centered modal-lg">
                                                    <div class="modal-content border-0 shadow rounded-4">
                                                        <div class="modal-header border-bottom-0 pb-0">
                                                            <h5 class="modal-title fw-bold" id="galleryLabel"><i class="bi bi-images text-info me-2"></i>Галерея
                                                                абстрактных фонов ИИ</h5>
                                                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                                                                        aria-label="Close"></button>
                                                            </div>
                                                            <div class="modal-body pb-4">
                                                                <p class="small text-white-50 mb-4">Выберите один из готовых художественных шаблонов для генерации
                                                                    видео.</p>
                                                                    <div class="row row-cols-1 row-cols-md-3 g-3">
                                                                        <!-- Plain Black Preset Choice -->
                                                                        <div class="col">
                                                                            <div class="card bg-transparent border-light border-opacity-10 rounded-4 overflow-hidden preset-choice-card cursor-pointer"
                                                                                 onclick="selectPreset('black')">
                                                                                <div class="d-flex align-items-center justify-content-center bg-black border-bottom border-light border-opacity-10"
                                                                                     style="height: 120px;">
                                                                                    <i class="bi bi-x-circle text-muted display-6"></i>
                                                                                </div>
                                                                                <div class="card-body p-3">
                                                                                    <h6 class="fw-bold text-white mb-1 small">Черный фон</h6>
                                                                                    <span class="text-white-50 small" style="font-size: 0.75rem;">Без фонового
                                                                                        изображения</span>
                                                                                    </div>
                                                                                </div>
                                                                            </div>
                                                                            <div class="col">
                                                                                <div class="card bg-transparent border-light border-opacity-10 rounded-4 overflow-hidden preset-choice-card cursor-pointer"
                                                                                     onclick="selectPreset('preset_cyberpunk')">
                                                                                    <img src="/images/presets/preset_cyberpunk.png" class="card-img-top preset-card-cyberpunk"
                                                                                         style="height: 120px; object-fit: cover;" />
                                                                                    <div class="card-body p-3">
                                                                                        <h6 class="fw-bold text-white mb-1 small">Cyberpunk Neon</h6>
                                                                                        <span class="text-white-50 small" style="font-size: 0.75rem;">Неоновые градиенты и
                                                                                            свечения</span>
                                                                                        </div>
                                                                                    </div>
                                                                                </div>
                                                                                <div class="col">
                                                                                    <div class="card bg-transparent border-light border-opacity-10 rounded-4 overflow-hidden preset-choice-card cursor-pointer"
                                                                                         onclick="selectPreset('preset_aurora')">
                                                                                        <img src="/images/presets/preset_aurora.png" class="card-img-top preset-card-aurora"
                                                                                             style="height: 120px; object-fit: cover;" />
                                                                                        <div class="card-body p-3">
                                                                                            <h6 class="fw-bold text-white mb-1 small">Aurora Wave</h6>
                                                                                            <span class="text-white-50 small" style="font-size: 0.75rem;">Зеленые и фиолетовые
                                                                                                переливы</span>
                                                                                            </div>
                                                                                        </div>
                                                                                    </div>
                                                                                    <div class="col">
                                                                                        <div class="card bg-transparent border-light border-opacity-10 rounded-4 overflow-hidden preset-choice-card cursor-pointer"
                                                                                             onclick="selectPreset('preset_nebula')">
                                                                                            <img src="/images/presets/preset_nebula.png" class="card-img-top preset-card-nebula"
                                                                                                 style="height: 120px; object-fit: cover;" />
                                                                                            <div class="card-body p-3">
                                                                                                <h6 class="fw-bold text-white mb-1 small">Cosmic Nebula</h6>
                                                                                                <span class="text-white-50 small" style="font-size: 0.75rem;">Космическое пылевое
                                                                                                    облако</span>
                                                                                                </div>
                                                                                            </div>
                                                                                        </div>
                                                                                        <div class="col">
                                                                                            <div class="card bg-transparent border-light border-opacity-10 rounded-4 overflow-hidden preset-choice-card cursor-pointer"
                                                                                                 onclick="selectPreset('preset_sunset')">
                                                                                                <img src="/images/presets/preset_sunset.png" class="card-img-top preset-card-sunset"
                                                                                                     style="height: 120px; object-fit: cover;" />
                                                                                                <div class="card-body p-3">
                                                                                                    <h6 class="fw-bold text-white mb-1 small">Sunset Aura</h6>
                                                                                                    <span class="text-white-50 small" style="font-size: 0.75rem;">Теплые тона заходящего
                                                                                                        солнца</span>
                                                                                                    </div>
                                                                                                </div>
                                                                                            </div>
                                                                                            <div class="col">
                                                                                                <div class="card bg-transparent border-light border-opacity-10 rounded-4 overflow-hidden preset-choice-card cursor-pointer"
                                                                                                     onclick="selectPreset('preset_oceanic')">
                                                                                                    <img src="/images/presets/preset_oceanic.png" class="card-img-top preset-card-oceanic"
                                                                                                         style="height: 120px; object-fit: cover;" />
                                                                                                    <div class="card-body p-3">
                                                                                                        <h6 class="fw-bold text-white mb-1 small">Oceanic Liquid</h6>
                                                                                                        <span class="text-white-50 small" style="font-size: 0.75rem;">Глубокие океанические
                                                                                                            волны</span>
                                                                                                        </div>
                                                                                                    </div>
                                                                                                </div>
                                                                                                <div class="col">
                                                                                                    <div class="card bg-transparent border-light border-opacity-10 rounded-4 overflow-hidden preset-choice-card cursor-pointer"
                                                                                                         onclick="selectPreset('preset_monochrome')">
                                                                                                        <img src="/images/presets/preset_monochrome.png" class="card-img-top preset-card-monochrome"
                                                                                                             style="height: 120px; object-fit: cover;" />
                                                                                                        <div class="card-body p-3">
                                                                                                            <h6 class="fw-bold text-white mb-1 small">Midnight Minimal</h6>
                                                                                                            <span class="text-white-50 small" style="font-size: 0.75rem;">Графитовый
                                                                                                                минимализм</span>
                                                                                                            </div>
                                                                                                        </div>
                                                                                                    </div>
                                                                                                </div>
                                                                                            </div>
                                                                                        </div>
                                                                                    </div>
                                                                                </div>

                                                                                <!-- Modal 2: Gemini Config Modal -->
                                                                                <div class="modal fade" id="geminiConfigModal" tabindex="-1" aria-labelledby="geminiConfigModalLabel"
                                                                                     aria-hidden="true">
                                                                                    <div class="modal-dialog modal-dialog-centered">
                                                                                        <div class="modal-content border-0 shadow rounded-4">
                                                                                            <div class="modal-header border-bottom-0 pb-0">
                                                                                                <h5 class="modal-title fw-bold" id="geminiConfigModalLabel"><i
                                                                                                    class="bi bi-magic me-2 text-primary"></i>Настройки Gemini ИИ</h5>
                                                                                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                                                                                                            aria-label="Close"></button>
                                                                                                </div>
                                                                                                <div class="modal-body pb-4">
                                                                                                    <div class="mb-3">
                                                                                                        <label for="geminiApiKeyModalInput" class="form-label small fw-bold text-white-50">Gemini API
                                                                                                            Key</label>
                                                                                                            <input type="password" id="geminiApiKeyModalInput" class="form-control form-control-lg rounded-3"
                                                                                                                   placeholder="AIzaSy..." autocomplete="off" />
                                                                                                            <div class="form-text small text-white-50">Ключ сохраняется локально в вашем браузере.</div>
                                                                                                        </div>
                                                                                                        <div class="form-check form-switch mb-4">
                                                                                                            <input class="form-check-input" type="checkbox" id="geminiAutoImproveModalInput" />
                                                                                                            <label class="form-check-label small fw-bold text-white-50"
                                                                                                                   for="geminiAutoImproveModalInput">Автоматическое улучшение субтитров при загрузке</label>
                                                                                                        </div>

                                                                                                        <div class="vstack gap-2">
                                                                                                            <button type="button" id="btnSaveGeminiConfig"
                                                                                                                    class="btn btn-primary btn-lg rounded-pill w-100 fw-bold">
                                                                                                                Сохранить настройки
                                                                                                            </button>
                                                                                                        </div>
                                                                                                    </div>
                                                                                                </div>
                                                                                            </div>
                                                                                        </div>

                                                                                        @section Scripts {
                                                                                            <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

                                                                                            <script>
                                                                                                const connection = new signalR.HubConnectionBuilder()
                                                                                                    .withUrl("/notificationHub")
                                                                                                    .withAutomaticReconnect()
                                                                                                    .build();

                                                                                                connection.on("UpdateTaskStatus", function (taskId, status, videoUrl) {
                                                                                                    const card = document.getElementById("task-" + taskId);
                                                                                                    if (!card) return;

                                                                                                    const statusTextSpan = card.querySelector(".task-status-text");
                                                                                                    const actionContainer = card.querySelector(".task-action");
                                                                                                    const progressCircle = card.querySelector(".circular-progress circle:nth-child(2)");
                                                                                                    const progressPercentSpan = card.querySelector(".task-progress-percent");

                                                                                                    let progressPercent = 0;

                                                                                                    if (status.startsWith("Processing")) {
                                                                                                        const match = status.match(/\d+/);
                                                                                                        progressPercent = match ? parseInt(match[0]) : 10;

                                                                                                        let textDescription = `Обработка`;
                                                                                                        if (status.includes("(")) {
                                                                                                            const subPhase = status.substring(status.indexOf("(") + 1, status.indexOf(")"));
                                                                                                            textDescription = subPhase;
                                                                                                        }

                                                                                                        if (statusTextSpan) {
                                                                                                            statusTextSpan.innerHTML = `<span class="text-warning"><i class="spinner-border spinner-border-sm me-1 flex-shrink-0" style="width:0.8rem;height:0.8rem;" role="status"></i>${textDescription}</span>`;
                                                                                                        }

                                                                                                        if (actionContainer) {
                                                                                                            actionContainer.innerHTML = `
                                                                                                                    <form method="post" action="/Dashboard?handler=Delete&taskId=${taskId}" onsubmit="return confirm('Прервать обработку и удалить файлы?');" class="d-inline m-0">
                                                                                                                        <input type="hidden" name="__RequestVerificationToken" value="${document.querySelector('input[name=\"__RequestVerificationToken\"]').value}" />
                                                                                                                        <button type="submit" class="btn btn-action-danger-glass"><i class="bi bi-trash"></i></button>
                                                                                                                    </form>`;
                                                                                                        }
                                                                                                    }
                                                                                                    else if (status === "AwaitingReview") {
                                                                                                        progressPercent = 80;
                                                                                                        if (statusTextSpan) {
                                                                                                            statusTextSpan.innerHTML = `<span class="text-info"><i class="bi bi-pencil-square me-1"></i>Ожидает проверки</span>`;
                                                                                                        }
                                                                                                        if (actionContainer) {
                                                                                                            actionContainer.innerHTML = `
                                                                                                                    <a href="/EditSubtitles?taskId=${taskId}" class="btn btn-action-glass" style="color: #ffc107 !important; border-color: rgba(255, 193, 7, 0.3) !important;">
                                                                                                                        <i class="bi bi-keyboard me-1"></i>Текст
                                                                                                                    </a>
                                                                                                                    <form method="post" action="/Dashboard?handler=Delete&taskId=${taskId}" onsubmit="return confirm('Вы уверены, что хотите удалить эту генерацию?');" class="d-inline m-0">
                                                                                                                        <input type="hidden" name="__RequestVerificationToken" value="${document.querySelector('input[name=\"__RequestVerificationToken\"]').value}" />
                                                                                                                        <button type="submit" class="btn btn-action-danger-glass"><i class="bi bi-trash"></i></button>
                                                                                                                    </form>`;
                                                                                                        }
                                                                                                    }
                                                                                                    else if (status === "ReadyToRender") {
                                                                                                        progressPercent = 90;
                                                                                                        if (statusTextSpan) {
                                                                                                            statusTextSpan.innerHTML = `<span class="text-primary"><i class="bi bi-gear-wide-connected me-1 animate-spin"></i>Сборка видео...</span>`;
                                                                                                        }
                                                                                                    }
                                                                                                    else if (status === "Completed") {
                                                                                                        progressPercent = 100;
                                                                                                        if (statusTextSpan) {
                                                                                                            statusTextSpan.innerHTML = `<span class="text-success"><i class="bi bi-check-circle-fill me-1"></i>Готово</span>`;
                                                                                                        }

                                                                                                        const fileNameDiv = card.querySelector(".fw-bold.text-truncate");
                                                                                                        let downloadName = "video.mp4";
                                                                                                        if (fileNameDiv) {
                                                                                                            const originalName = fileNameDiv.innerText.trim();
                                                                                                            downloadName = originalName.replace(/\.[^/.]+$/, "") + ".mp4";
                                                                                                        }

                                                                                                        if (actionContainer) {
                                                                                                            actionContainer.innerHTML = `
                                                                                                                    <a href="/${videoUrl}" class="btn btn-action-glass" download="${downloadName}">
                                                                                                                        <i class="bi bi-download me-1"></i>MP4
                                                                                                                    </a>
                                                                                                                    <a href="/EditSubtitles?taskId=${taskId}" class="btn btn-action-glass" style="color: #ffc107 !important; border-color: rgba(255, 193, 7, 0.3) !important;">
                                                                                                                        <i class="bi bi-pencil-square me-1"></i>Изменить
                                                                                                                    </a>
                                                                                                                    <form method="post" action="/Dashboard?handler=Delete&taskId=${taskId}" onsubmit="return confirm('Вы уверены, что хотите удалить эту генерацию?');" class="d-inline m-0">
                                                                                                                        <input type="hidden" name="__RequestVerificationToken" value="${document.querySelector('input[name=\"__RequestVerificationToken\"]').value}" />
                                                                                                                        <button type="submit" class="btn btn-action-danger-glass"><i class="bi bi-trash"></i></button>
                                                                                                                    </form>`;
                                                                                                        }

                                                                                                        card.classList.add("table-row-flash-success");
                                                                                                        setTimeout(() => card.classList.remove("table-row-flash-success"), 2500);
                                                                                                    }
                                                                                                    else if (status === "Failed") {
                                                                                                        progressPercent = 100;
                                                                                                        if (statusTextSpan) {
                                                                                                            statusTextSpan.innerHTML = `<span class="text-danger"><i class="bi bi-exclamation-triangle-fill me-1"></i>Ошибка</span>`;
                                                                                                        }
                                                                                                        if (actionContainer) {
                                                                                                            actionContainer.innerHTML = `
                                                                                                                    <button class="btn btn-action-glass" disabled><i class="bi bi-dash-lg"></i></button>
                                                                                                                    <form method="post" action="/Dashboard?handler=Delete&taskId=${taskId}" onsubmit="return confirm('Вы уверены, что хотите удалить эту генерацию?');" class="d-inline m-0">
                                                                                                                        <input type="hidden" name="__RequestVerificationToken" value="${document.querySelector('input[name=\"__RequestVerificationToken\"]').value}" />
                                                                                                                        <button type="submit" class="btn btn-action-danger-glass"><i class="bi bi-trash"></i></button>
                                                                                                                    </form>`;
                                                                                                        }
                                                                                                    }

                                                                                                    if (progressCircle) {
                                                                                                        progressCircle.setAttribute("stroke-dashoffset", 100 - progressPercent);
                                                                                                    }
                                                                                                    if (progressPercentSpan) {
                                                                                                        progressPercentSpan.innerText = progressPercent + "%";
                                                                                                    }
                                                                                                });

                                                                                                connection.start().catch(function (err) {
                                                                                                    return console.error(err.toString());
                                                                                                });

                                                                                                // Config Elements Drag and Drop & Change logic
                                                                                                const audioFileInput = document.getElementById('audioFileInput');
                                                                                                const audioFilenameText = document.getElementById('audioFilenameText');
                                                                                                audioFileInput.addEventListener('change', () => {
                                                                                                    if (audioFileInput.files.length > 0) {
                                                                                                        audioFilenameText.innerText = "🎵 " + audioFileInput.files[0].name;
                                                                                                        audioFilenameText.classList.add('text-success');
                                                                                                    }
                                                                                                });

                                                                                                const bgFileInput = document.getElementById('bgFileInput');
                                                                                                const bgFilenameText = document.getElementById('bgFilenameText');
                                                                                                bgFileInput.addEventListener('change', () => {
                                                                                                    if (bgFileInput.files.length > 0) {
                                                                                                        bgFilenameText.innerText = "🖼️ " + bgFileInput.files[0].name;
                                                                                                        bgFilenameText.classList.add('text-info');
                                                                                                        document.getElementById('dashboardSelectedPresetBg').value = '';

                                                                                                        const reader = new FileReader();
                                                                                                        reader.onload = (e) => {
                                                                                                            const img = document.getElementById('playerBgImage');
                                                                                                            img.src = e.target.result;
                                                                                                            img.className = 'player-preview-bg';
                                                                                                        };
                                                                                                        reader.readAsDataURL(bgFileInput.files[0]);
                                                                                                    }
                                                                                                });

                                                                                                function selectPreset(presetName) {
                                                                                                    applyBackgroundPreset(presetName);
                                                                                                    const modalEl = document.getElementById('presetGalleryModal');
                                                                                                    const modal = bootstrap.Modal.getInstance(modalEl);
                                                                                                    if (modal) modal.hide();
                                                                                                }

                                                                                                function applyBackgroundPreset(presetName) {
                                                                                                    const cleanName = presetName.replace('.png', '');
                                                                                                    const img = document.getElementById('playerBgImage');

                                                                                                    if (cleanName === 'black') {
                                                                                                        img.src = 'data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7';
                                                                                                        img.className = 'player-preview-bg bg-black';
                                                                                                        document.getElementById('dashboardSelectedPresetBg').value = 'black';
                                                                                                        localStorage.setItem('SelectedPresetBg', 'black');
                                                                                                    } else {
                                                                                                        img.src = `/images/presets/${cleanName}.png`;
                                                                                                        img.className = `player-preview-bg preset-card-${cleanName}`;
                                                                                                        document.getElementById('dashboardSelectedPresetBg').value = cleanName + '.png';
                                                                                                        localStorage.setItem('SelectedPresetBg', cleanName + '.png');
                                                                                                    }

                                                                                                    bgFileInput.value = '';
                                                                                                    bgFilenameText.innerText = "Загрузить изображение или видео";
                                                                                                    bgFilenameText.classList.remove('text-info');

                                                                                                    // Apply selected visual feedback borders in modal
                                                                                                    const cards = document.querySelectorAll('.preset-choice-card');
                                                                                                    cards.forEach(c => {
                                                                                                        c.classList.remove('selected');
                                                                                                        const isBlackCard = c.querySelector('.bg-black') !== null;
                                                                                                        const imgEl = c.querySelector('img');

                                                                                                        if (cleanName === 'black' && isBlackCard) {
                                                                                                            c.classList.add('selected');
                                                                                                        } else if (imgEl && imgEl.src.includes(cleanName) && cleanName !== 'black') {
                                                                                                            c.classList.add('selected');
                                                                                                        }
                                                                                                    });
                                                                                                }

                                                                                                // Live visual subtitle settings updates
                                                                                                const fontSelect = document.getElementById('configFont');
                                                                                                const priColorSelect = document.getElementById('configPrimaryColor');
                                                                                                const secColorSelect = document.getElementById('configSecondaryColor');
                                                                                                const formatSelect = document.getElementById('configVideoFormat');
                                                                                                const previewContainer = document.querySelector('.player-preview-container');
                                                                                                
                                                                                                function applyFontAndStylePreview(font, fill, priCol, secCol) {
                                                                                                    const line1 = document.getElementById('previewSubLine1');
                                                                                                
                                                                                                    if (line1) {
                                                                                                        line1.style.fontFamily = font;
                                                                                                
                                                                                                        const cssPri = priCol.startsWith('#') ? priCol : ({
                                                                                                            white: '#ffffff',
                                                                                                            lightgray: '#d3d3d3',
                                                                                                            cyan: '#00ffff',
                                                                                                            yellow: '#ffff00'
                                                                                                        }[priCol] || '#ffffff');
                                                                                                
                                                                                                        const cssSec = secCol.startsWith('#') ? secCol : ({
                                                                                                            purple: '#a855f7',
                                                                                                            red: '#ef4444',
                                                                                                            yellow: '#eab308',
                                                                                                            green: '#22c55e',
                                                                                                            cyan: '#06b6d4'
                                                                                                        }[secCol] || '#a855f7');
                                                                                                
                                                                                                        line1.style.color = cssPri;
                                                                                                
                                                                                                        // Анимация закрашивания теперь всегда "gradient" (плавный градиент)
                                                                                                        line1.style.textShadow = `0 2px 4px rgba(0,0,0,0.8), 0 0 20px ${cssSec}80`;
                                                                                                        line1.innerHTML = `<span style="color:${cssSec}; font-weight: 800;">Я люблю эт</span>от красивый караоке плеер`;
                                                                                                    }
                                                                                                }
                                                                                                
                                                                                                function updateColorPickerUI() {
                                                                                                    const priVal = priColorSelect.value;
                                                                                                    const secVal = secColorSelect.value;
                                                                                                    
                                                                                                    const priWheel = document.getElementById('configPrimaryColorWheel');
                                                                                                    const secWheel = document.getElementById('configSecondaryColorWheel');
                                                                                                    const priHex = document.getElementById('primaryColorHex');
                                                                                                    const secHex = document.getElementById('secondaryColorHex');
                                                                                                    
                                                                                                    if (priWheel) priWheel.style.backgroundColor = priVal;
                                                                                                    if (priHex) priHex.textContent = priVal.toUpperCase();
                                                                                                    
                                                                                                    if (secWheel) secWheel.style.backgroundColor = secVal;
                                                                                                    if (secHex) secHex.textContent = secVal.toUpperCase();
                                                                                                }
                                                                                                
                                                                                                fontSelect.addEventListener('change', () => {
                                                                                                    localStorage.setItem('SubtitleFont', fontSelect.value);
                                                                                                    applyFontAndStylePreview(fontSelect.value, 'gradient', priColorSelect.value, secColorSelect.value);
                                                                                                });
                                                                                                
                                                                                                priColorSelect.addEventListener('input', () => {
                                                                                                    updateColorPickerUI();
                                                                                                    localStorage.setItem('PrimaryColor', priColorSelect.value);
                                                                                                    applyFontAndStylePreview(fontSelect.value, 'gradient', priColorSelect.value, secColorSelect.value);
                                                                                                });
                                                                                                
                                                                                                secColorSelect.addEventListener('input', () => {
                                                                                                    updateColorPickerUI();
                                                                                                    localStorage.setItem('SecondaryColor', secColorSelect.value);
                                                                                                    applyFontAndStylePreview(fontSelect.value, 'gradient', priColorSelect.value, secColorSelect.value);
                                                                                                });
                                                                                                
                                                                                                function applyVideoFormatPreview(fmt) {
                                                                                                    if (!previewContainer) return;
                                                                                                    if (fmt === 'landscape') {
                                                                                                        previewContainer.style.aspectRatio = '16/9';
                                                                                                        previewContainer.style.maxHeight = '280px';
                                                                                                        previewContainer.style.maxWidth = '100%';
                                                                                                    } else {
                                                                                                        previewContainer.style.aspectRatio = '9/16';
                                                                                                        previewContainer.style.maxHeight = '420px';
                                                                                                        previewContainer.style.maxWidth = '240px';
                                                                                                    }
                                                                                                }
                                                                                                
                                                                                                if (formatSelect) {
                                                                                                    formatSelect.addEventListener('change', () => {
                                                                                                        localStorage.setItem('VideoFormat', formatSelect.value);
                                                                                                        applyVideoFormatPreview(formatSelect.value);
                                                                                                    });
                                                                                                }
                                                                                                
                                                                                                // Config persistence loaders
                                                                                                const langSelect = document.getElementById('configLanguage');
                                                                                                const qualSelect = document.getElementById('configQuality');
                                                                                                const vocalSwitch = document.getElementById('removeVocalSwitch');
                                                                                                
                                                                                                langSelect.addEventListener('change', () => localStorage.setItem('SelectedLanguage', langSelect.value));
                                                                                                qualSelect.addEventListener('change', () => localStorage.setItem('SelectedQuality', qualSelect.value));
                                                                                                vocalSwitch.addEventListener('change', () => localStorage.setItem('RemoveVocal', vocalSwitch.checked));
                                                                                                
                                                                                                function loadLocalConfig() {
                                                                                                    const config = {
                                                                                                        apiKey: localStorage.getItem('geminiApiKey') || '',
                                                                                                        autoImprove: localStorage.getItem('geminiAutoImprove') === 'true',
                                                                                                        lang: localStorage.getItem('SelectedLanguage') || 'auto',
                                                                                                        quality: localStorage.getItem('SelectedQuality') || 'medium',
                                                                                                        font: localStorage.getItem('SubtitleFont') || 'Outfit',
                                                                                                        priColor: localStorage.getItem('PrimaryColor') || '#ffffff',
                                                                                                        secColor: localStorage.getItem('SecondaryColor') || '#a855f7',
                                                                                                        videoFormat: localStorage.getItem('VideoFormat') || 'portrait',
                                                                                                        removeVocal: localStorage.getItem('RemoveVocal') !== 'false',
                                                                                                        preset: localStorage.getItem('SelectedPresetBg') || 'preset_cyberpunk.png'
                                                                                                    };
                                                                                                
                                                                                                    document.getElementById('dashboardGeminiApiKey').value = config.apiKey;
                                                                                                    document.getElementById('dashboardAutoImproveEnabled').value = config.autoImprove;
                                                                                                
                                                                                                    const modalKey = document.getElementById('geminiApiKeyModalInput');
                                                                                                    const modalSwitch = document.getElementById('geminiAutoImproveModalInput');
                                                                                                    if (modalKey) modalKey.value = config.apiKey;
                                                                                                    if (modalSwitch) modalSwitch.checked = config.autoImprove;
                                                                                                
                                                                                                    langSelect.value = config.lang;
                                                                                                    qualSelect.value = config.quality;
                                                                                                    fontSelect.value = config.font;
                                                                                                    priColorSelect.value = config.priColor;
                                                                                                    secColorSelect.value = config.secColor;
                                                                                                    vocalSwitch.checked = config.removeVocal;
                                                                                                    if (formatSelect) formatSelect.value = config.videoFormat;
                                                                                                
                                                                                                    applyBackgroundPreset(config.preset);
                                                                                                    updateGeminiStatusLabel(config.apiKey, config.autoImprove);
                                                                                                    updateColorPickerUI();
                                                                                                    applyFontAndStylePreview(config.font, 'gradient', config.priColor, config.secColor);
                                                                                                    applyVideoFormatPreview(config.videoFormat);
                                                                                                }

                                                                                                function updateGeminiStatusLabel(key, auto) {
                                                                                                    const label = document.getElementById('geminiStatusLabel');
                                                                                                    if (label) {
                                                                                                        if (key) {
                                                                                                            label.innerText = `Статус: Включено${auto ? ' (Автоулучшение)' : ''}`;
                                                                                                            label.className = "small text-success fw-bold";
                                                                                                        } else {
                                                                                                            label.innerText = "Статус: Выключено (нет API ключа)";
                                                                                                            label.className = "small text-white-50";
                                                                                                        }
                                                                                                    }
                                                                                                }

                                                                                                document.getElementById('btnSaveGeminiConfig').addEventListener('click', () => {
                                                                                                    const key = document.getElementById('geminiApiKeyModalInput').value.trim();
                                                                                                    const auto = document.getElementById('geminiAutoImproveModalInput').checked;

                                                                                                    localStorage.setItem('geminiApiKey', key);
                                                                                                    localStorage.setItem('geminiAutoImprove', auto ? 'true' : 'false');

                                                                                                    document.getElementById('dashboardGeminiApiKey').value = key;
                                                                                                    document.getElementById('dashboardAutoImproveEnabled').value = auto ? 'true' : 'false';

                                                                                                    updateGeminiStatusLabel(key, auto);

                                                                                                    const modalEl = document.getElementById('geminiConfigModal');
                                                                                                    const modalInstance = bootstrap.Modal.getInstance(modalEl);
                                                                                                    if (modalInstance) modalInstance.hide();
                                                                                                });

                                                                                                // Intercept uploadForm to feed values
                                                                                                document.getElementById('uploadForm').addEventListener('submit', () => {
                                                                                                    document.getElementById('dashboardGeminiApiKey').value = localStorage.getItem('geminiApiKey') || '';
                                                                                                    document.getElementById('dashboardAutoImproveEnabled').value = localStorage.getItem('geminiAutoImprove') === 'true' ? 'true' : 'false';
                                                                                                });

                                                                                                // Initialize configuration on load
                                                                                                loadLocalConfig();
                                                                                            </script>
                                                                                        }