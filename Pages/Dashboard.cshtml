@page
@using KaraokePlatform.Data.Entities
@using System.IO
@model DashboardModel
@{
    ViewData["Title"] = "Личный кабинет";
}

<style>
    /* UI-фикс: меняем курсор на pointer для интерактивных элементов формы */
    .form-check-switch-pointer .form-check-input,
    .form-check-switch-pointer .form-check-label,
    .form-select-pointer {
        cursor: pointer !important;
    }
</style>

<div class="container py-5">
    <div class="row align-items-center justify-content-between mb-5 g-3">
        <div class="col shadow-none">
            <h1 class="h2 fw-bold text-dark mb-1">Добро пожаловать, @User.Identity?.Name</h1>
            <p class="text-muted mb-0">Ваша личная студия обработки audio в караоке-видео.</p>
        </div>
        @* Кнопка отображается только если у пользователя есть роль Admin *@
        @if (User.IsInRole("Admin"))
        {
            <div class="col-auto text-end">
                <a asp-page="/Admin/ManageUsers" class="btn btn-outline-danger btn-lg fw-bold rounded-3 shadow-sm px-4">
                    <i class="bi bi-shield-lock-fill me-2"></i>Панель администратора
                </a>
            </div>
        }
    </div>

    <div class="row g-4">
        @* Форма загрузки *@
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm p-4 rounded-4">
                <h5 class="fw-bold mb-3">Загрузить трек</h5>
                <form method="post" asp-page-handler="Upload" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label class="form-label text-muted small">Файл MP3</label>
                        <input asp-for="UploadedAudio" class="form-control form-control-lg" type="file" accept=".mp3"
                               required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small">Фоновое изображение (необязательно)</label>
                        <input asp-for="UploadedBackground" class="form-control form-control-lg" type="file"
                               accept=".jpg,.jpeg,.png" />
                        <div class="form-text small text-muted">Если не выбрать, фон останется черным.</div>
                    </div>
                    <div class="mb-3">
                        @* ИСПРАВЛЕНО: Добавлен вспомогательный класс form-check-switch-pointer *@
                        <div
                            class="form-check form-switch p-3 bg-light rounded-3 border border-light-subtle form-check-switch-pointer">
                            <input asp-for="RemoveVocal" class="form-check-input ms-0 me-2" type="checkbox"
                                   role="switch" id="removeVocalSwitch" checked>
                            <label class="form-check-label fw-semibold text-dark" for="removeVocalSwitch">🤫 Удалить
                                оригинальный вокал</label>
                                <div class="form-text small text-muted ps-0 mt-1">Если включено, ИИ вырежет голос и создаст
                                    чистую минусовку. Если выключено — голос останется.</div>
                                </div>
                            </div>
                            <div class="mb-4">
                                <label class="form-label text-muted small">Язык</label>
                                @* ИСПРАВЛЕНО: Добавлен класс form-select-pointer *@
                                <select asp-for="SelectedLanguage" class="form-select form-select-lg form-select-pointer">
                                    <option value="auto">🌍 Автоматически</option>
                                    <option value="ru">🇷🇺 Русский</option>
                                    <option value="en">🇺🇸 Английский</option>
                                </select>
                            </div>
                            <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold">Начать обработку</button>
                        </form>
                    </div>
                </div>

                @* Таблица задач *@
                <div class="col-lg-8">
                    <div class="card shadow-sm border-0 rounded-4">
                        <div class="card-body p-4">
                            <h5 class="card-title mb-4 fw-bold">Мои генерации</h5>

                            @if (!Model.UserTasks.Any())
                            {
                                <div class="text-center py-5 text-muted">
                                    <i class="bi bi-music-note-beamed display-4 mb-3 d-block text-secondary opacity-50"></i>
                                    <p class="mb-0">Вы еще не загрузили ни одного трека.</p>
                                </div>
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle" style="table-layout: fixed; width: 100%;">
                                        <thead class="table-light">
                                            <tr>
                                                <th style="width: 30%; font-size: 0.85rem;" class="text-secondary">Файл</th>
                                                <th style="width: 20%; font-size: 0.85rem;" class="text-secondary">Дата</th>
                                                <th style="width: 25%; font-size: 0.85rem;" class="text-secondary">Статус</th>
                                                <th style="width: 25%; font-size: 0.85rem;" class="text-secondary text-end">
                                                    Результат</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var task in Model.UserTasks)
                                                {
                                                    <tr id="task-@task.Id">
                                                        <td class="fw-bold text-truncate" title="@task.OriginalFileName">
                                                            @task.OriginalFileName
                                                        </td>
                                                        <td class="small text-muted">@task.CreatedAt.ToLocalTime().ToString("g")</td>
                                                        <td class="task-status">
                                                            @if (task.Status == KaraokeTaskStatus.InQueue)
                                                            {
                                                                <span class="text-secondary small"><i class="bi bi-hourglass-split me-1"></i>В
                                                                    очереди</span>
                                                                }
                                                else if (task.Status == KaraokeTaskStatus.Processing)
                                                                {
                                                                    <div class="processing-container">
                                                                        <div class="d-flex align-items-center text-warning small mb-1 text-nowrap">
                                                                            <div class="spinner-border spinner-border-sm me-2 flex-shrink-0"
                                                                                 role="status"></div>
                                                                            <span class="processing-text">Обработка...</span>
                                                                        </div>
                                                                        <div class="progress" style="height: 4px; background-color: #f0f0f0;">
                                                                            <div class="progress-bar progress-bar-striped progress-bar-animated bg-warning"
                                                                                 role="progressbar" style="width: 10%"></div>
                                                                        </div>
                                                                    </div>
                                                                }
                                                                else if (task.Status == KaraokeTaskStatus.AwaitingReview)
                                                                {
                                                                    <span class="text-warning small text-nowrap"><i
                                                                        class="bi bi-pencil-square me-1"></i>Ожидает проверки</span>
                                                                    }
                                                else if (task.Status == KaraokeTaskStatus.Completed)
                                                                    {
                                                                        <span class="text-success small"><i
                                                                            class="bi bi-check-circle-fill me-1"></i>Готово</span>
                                                                        }
                                                else if (task.Status == KaraokeTaskStatus.Failed)
                                                                        {
                                                                            <span class="text-danger small"
                                                                                  title="@(string.IsNullOrEmpty(task.ErrorMessage) ? "Ошибка обработки" : task.ErrorMessage)">
                                                                                <i class="bi bi-exclamation-triangle-fill me-1"></i>Ошибка
                                                                            </span>
                                                                        }
                                                                    </td>
                                                                    <td class="task-action text-end">
                                                                        <div class="d-flex justify-content-end align-items-center gap-2">
                                                                            @if (task.Status == KaraokeTaskStatus.Completed &&
                                                                    !string.IsNullOrEmpty(task.VideoFilePath))
                                                                            {
                                                                                var downloadName =
                                                                    System.IO.Path.GetFileNameWithoutExtension(task.OriginalFileName) + ".mp4";

                                                                                <a href="/@task.VideoFilePath"
                                                                                   class="btn btn-sm btn-outline-success rounded-3 px-3"
                                                                                   download="@downloadName">
                                                                                    <i class="bi bi-download me-1"></i>MP4
                                                                                </a>
                                                                            }
                                                                            else if (task.Status == KaraokeTaskStatus.AwaitingReview)
                                                                            {
                                                                                <a asp-page="/EditSubtitles" asp-route-taskId="@task.Id"
                                                                                   class="btn btn-sm btn-warning text-dark fw-bold rounded-3 px-3">
                                                                                    <i class="bi bi-keyboard me-1"></i>Текст
                                                                                </a>
                                                                            }
                                                                            else if (task.Status == KaraokeTaskStatus.Processing)
                                                                            {
                                                                                <button class="btn btn-sm btn-light rounded-3 text-muted" disabled>
                                                                                    <i class="bi bi-cpu"></i>
                                                                                </button>
                                                                            }
                                                                            else
                                                                            {
                                                                                <button class="btn btn-sm btn-light rounded-3 text-muted" disabled>
                                                                                    <i class="bi bi-dash-lg"></i>
                                                                                </button>
                                                                            }

                                                                            <form method="post" asp-page-handler="Delete" asp-route-taskId="@task.Id"
                                                                                  onsubmit="return confirm('Вы уверены, что хотите прервать обработку и безвозвратно удалить эту генерацию и все файлы?');"
                                                                                  class="d-inline m-0">
                                                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-3"
                                                                                        title="Прервать и удалить">
                                                                                    <i class="bi bi-trash"></i>
                                                                                </button>
                                                                            </form>
                                                                        </div>
                                                                    </td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @section Scripts {
                            <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
                            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

                            <script>
                                const connection = new signalR.HubConnectionBuilder()
                                    .withUrl("/notificationHub")
                                    .withAutomaticReconnect()
                                    .build();

                                connection.on("UpdateTaskStatus", function (taskId, status, videoUrl) {
                                    const row = document.getElementById("task-" + taskId);
                                    if (!row) return;

                                    const statusCell = row.querySelector(".task-status");
                                    const actionCell = row.querySelector(".task-action");

                                    if (status.startsWith("Processing")) {
                                        let container = statusCell.querySelector(".processing-container");

                                        if (!container) {
                                            statusCell.innerHTML = `
                                                    <div class="processing-container">
                                                    <div class="d-flex align-items-center text-warning small mb-1 text-nowrap">
                                                    <div class="spinner-border spinner-border-sm me-2 flex-shrink-0" role="status"></div>
                                                    <span class="processing-text">Обработка...</span>
                                                    </div>
                                                    <div class="progress" style="height: 4px; background-color: #f0f0f0;">
                                                    <div class="progress-bar progress-bar-striped progress-bar-animated bg-warning" role="progressbar" style="width: 10%"></div>
                                                    </div>
                                                    </div>`;
                                            container = statusCell.querySelector(".processing-container");
                                        }

                                        const textElement = container.querySelector(".processing-text");
                                        const progressBar = container.querySelector(".progress-bar");

                                        const match = status.match(/\d+/);
                                        const percent = match ? match[0] : "10";

                                        let textDescription = `Обработка: ${percent}%`;
                                        if (status.includes("(")) {
                                            const subPhase = status.substring(status.indexOf("(") + 1, status.indexOf(")"));
                                            textDescription = `${subPhase} (${percent}%)`;
                                        }

                                        if (textElement) textElement.innerText = textDescription;
                                        if (progressBar) progressBar.style.width = percent + "%";

                                        actionCell.innerHTML = `
                                                <div class="d-flex justify-content-end align-items-center gap-2">
                                                    <form method="post" action="/Dashboard?handler=Delete&taskId=${taskId}" onsubmit="return confirm('Прервать обработку и безвозвратно удалить все файлы?');" class="d-inline m-0">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-3"><i class="bi bi-trash"></i></button>
                                                    </form>
                                                </div>`;
                                    }
                                    else if (status === "AwaitingReview") {
                                        statusCell.innerHTML = `<span class="text-warning small text-nowrap"><i class="bi bi-pencil-square me-1"></i>Ожидает проверки</span>`;
                                        actionCell.innerHTML = `
                                                <div class="d-flex justify-content-end align-items-center gap-2">
                                                    <a href="/EditSubtitles?taskId=${taskId}" class="btn btn-sm btn-warning text-dark fw-bold rounded-3 px-3">
                                                        <i class="bi bi-keyboard me-1"></i>Текст
                                                    </a>
                                                    <form method="post" action="/Dashboard?handler=Delete&taskId=${taskId}" onsubmit="return confirm('Вы уверены, что хотите удалить эту генерацию?');" class="d-inline m-0">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-3"><i class="bi bi-trash"></i></button>
                                                    </form>
                                                </div>`;
                                    }
                                    else if (status === "Completed") {
                                        statusCell.innerHTML = `<span class="text-success small"><i class="bi bi-check-circle-fill me-1"></i>Готово</span>`;

                                        const fileNameCell = row.querySelector("td.text-truncate");
                                        let downloadName = "video.mp4";
                                        if (fileNameCell) {
                                            const originalName = fileNameCell.innerText.trim();
                                            downloadName = originalName.replace(/\.[^/.]+$/, "") + ".mp4";
                                        }

                                        actionCell.innerHTML = `
                                                <div class="d-flex justify-content-end align-items-center gap-2">
                                                    <a href="/${videoUrl}" class="btn btn-sm btn-outline-success rounded-3 px-3" download="${downloadName}">
                                                        <i class="bi bi-download me-1"></i>MP4
                                                    </a>
                                                    <form method="post" action="/Dashboard?handler=Delete&taskId=${taskId}" onsubmit="return confirm('Вы уверены, что хотите удалить эту генерацию?');" class="d-inline m-0">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-3"><i class="bi bi-trash"></i></button>
                                                    </form>
                                                </div>`;

                                        row.classList.add("table-success");
                                        setTimeout(() => row.classList.remove("table-success"), 2500);
                                    }
                                    else if (status === "Failed") {
                                        statusCell.innerHTML = `<span class="text-danger small"><i class="bi bi-exclamation-triangle-fill me-1"></i>Ошибка</span>`;

                                        actionCell.innerHTML = `
                                                <div class="d-flex justify-content-end align-items-center gap-2">
                                                    <button class="btn btn-sm btn-light rounded-3 text-muted" disabled><i class="bi bi-dash-lg"></i></button>
                                                    <form method="post" action="/Dashboard?handler=Delete&taskId=${taskId}" onsubmit="return confirm('Вы уверены, что хотите удалить эту генерацию?');" class="d-inline m-0">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-3"><i class="bi bi-trash"></i></button>
                                                    </form>
                                                </div>`;
                                    }
                                });

                                connection.start().catch(function (err) {
                                    return console.error(err.toString());
                                });
                            </script>
                        }